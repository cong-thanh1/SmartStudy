# Local Docker Compose values only. Replace these outside local development.
POSTGRES_DB=smartstudy
POSTGRES_USER=smartstudy
POSTGRES_PASSWORD=change-me-local-postgres
POSTGRES_PORT=127.0.0.1:5432
DATABASE_URL=postgresql://smartstudy:change-me-local-postgres@localhost:5432/smartstudy

REDIS_PORT=127.0.0.1:6379
REDIS_URL=redis://localhost:6379
QUEUE_PREFIX=smartstudy
QUEUE_PRODUCER_MAX_RETRIES_PER_REQUEST=1
QUEUE_WORKER_CONCURRENCY=1

# Amazon SQS (set QUEUE_PROVIDER=sqs; configure redrive/DLQ in IaC).
SQS_QUEUE_NAME=document-processing
SQS_QUEUE_URL=
SQS_WAIT_TIME_SECONDS=20
SQS_VISIBILITY_TIMEOUT_SECONDS=120
SQS_POLL_ERROR_DELAY_MILLISECONDS=1000

DOCUMENT_MAX_SIZE_BYTES=52428800
DOCUMENT_UPLOAD_URL_EXPIRES_SECONDS=900
DOCUMENT_PROCESSING_QUEUE=document-processing
DOCUMENT_PROCESSING_ATTEMPTS=3
DOCUMENT_CHUNK_MAX_TOKENS=700
DOCUMENT_CHUNK_OVERLAP_TOKENS=80

MINIO_ROOT_USER=smartstudy-local
MINIO_ROOT_PASSWORD=change-me-local-minio
MINIO_BUCKET=smartstudy-documents
MINIO_API_PORT=127.0.0.1:9000
MINIO_CONSOLE_PORT=127.0.0.1:9001

STORAGE_ENDPOINT=http://localhost:9000
STORAGE_PUBLIC_ENDPOINT=http://localhost:8080
STORAGE_REGION=us-east-1
STORAGE_BUCKET=smartstudy-documents
STORAGE_ACCESS_KEY=smartstudy-local
STORAGE_SECRET_KEY=change-me-local-minio
STORAGE_URL_EXPIRES_SECONDS=900

API_PORT=127.0.0.1:3000
WEB_PORT=8080
VITE_API_URL=/api/v1

# Provider selection. Phase 5 can swap names without changing business logic.
STORAGE_PROVIDER=s3-compatible
VECTOR_STORE=pgvector
LLM_PROVIDER=llama-cpp
EMBEDDING_PROVIDER=local
AUTH_PROVIDER=jwt
QUEUE_PROVIDER=redis
EMAIL_PROVIDER=smtp

# JWT auth. Generate a unique secret with at least 32 characters.
JWT_SECRET=
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# Amazon Cognito (set AUTH_PROVIDER=cognito). Configure a public app client
# without a client secret and enable USER_PASSWORD_AUTH. The existing register
# endpoint expects the User Pool to auto-confirm sign-ups; email-confirmation
# flows require a dedicated API contract before production use.
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_REFRESH_TTL_SECONDS=2592000
JWT_ISSUER=smartstudy-api
JWT_AUDIENCE=smartstudy-web
BCRYPT_COST=12

# Anthropic direct API (local development).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_MAX_RETRIES=2
ANTHROPIC_TIMEOUT_MILLISECONDS=120000

# Amazon Bedrock (set LLM_PROVIDER=bedrock; authenticate through the AWS SDK
# default credential chain, for example an IAM role in Lambda/ECS or AWS SSO).
BEDROCK_REGION=us-east-1
BEDROCK_MODEL=anthropic.claude-3-5-haiku-20241022-v1:0
BEDROCK_MAX_TOKENS=4096
BEDROCK_MAX_RETRIES=2
BEDROCK_TIMEOUT_MILLISECONDS=120000

# Amazon Bedrock embeddings (set EMBEDDING_PROVIDER=bedrock).
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0
BEDROCK_EMBEDDING_BATCH_SIZE=8
BEDROCK_EMBEDDING_TIMEOUT_MILLISECONDS=120000

# Gemini API (set LLM_PROVIDER=gemini to use this adapter).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_TOKENS=4096
GEMINI_TIMEOUT_MILLISECONDS=120000

# Local AI through Ollama. qwen2.5:0.5b is the low-memory default.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:0.5b
OLLAMA_MAX_TOKENS=1024
OLLAMA_TIMEOUT_MILLISECONDS=120000

# Lightweight local AI through llama.cpp (Qwen2.5 0.5B Q4 GGUF, about 400 MB).
LLAMA_CPP_BASE_URL=http://localhost:8081
LLAMA_CPP_MAX_TOKENS=1024
LLAMA_CPP_TIMEOUT_MILLISECONDS=120000

# Local multilingual BGE-M3 embeddings (1024 dimensions).
EMBEDDING_MODEL=onnx-community/bge-m3-ONNX
EMBEDDING_DTYPE=q8
EMBEDDING_BATCH_SIZE=8
EMBEDDING_CACHE_DIR=.cache/huggingface

# Optional sample account used by `npm run prisma:seed`.
SEED_USER_EMAIL=student@example.com
SEED_USER_PASSWORD=
SEED_USER_FULL_NAME=SmartStudy Student
# Quiz generation reliability
QUIZ_GENERATION_ATTEMPTS_PER_SLOT=5
QUIZ_TOP_UP_SLOT_MULTIPLIER=2
QUIZ_LEXICAL_DUPLICATE_THRESHOLD=0.88
QUIZ_ANSWER_DUPLICATE_THRESHOLD=0.92
